# Copy this file to .streamlit/secrets.toml for LOCAL Streamlit dev,
# or paste these key/value pairs into the "Secrets" UI when deploying on
# Streamlit Community Cloud. The dashboard surfaces these as environment
# variables before importing the trading_droppers package.
#
# secrets.toml is gitignored; secrets.toml.example IS committed.

# SEC requires a descriptive User-Agent with contact info. Format:
#   "app-name your-email@example.com"
SEC_USER_AGENT = "trading-droppers your-email@example.com"
