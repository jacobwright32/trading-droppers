# Copy to .env and fill in. .env is gitignored.

# SEC EDGAR REQUIRES a descriptive User-Agent containing contact info, or it
# blocks the request. Format: "app-name your-email@example.com"
SEC_USER_AGENT=trading-droppers your-email@example.com

# --- Optional LLM narrative layer (off by default) ---
TD_LLM_ENABLED=false
TD_LLM_PROVIDER=anthropic          # anthropic | openai | ollama
# TD_LLM_MODEL=claude-haiku-4-5    # blank = provider default
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Optional pipeline overrides ---
# TD_PRICE_PERIOD=6y
# TD_PRICE_INTERVAL=1wk
# TD_YF_BATCH=120
# TD_DB_PATH=
